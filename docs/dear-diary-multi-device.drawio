  <diagram id="dear-diary-multi-device" name="Dear Diary Multi-Device Sync">
    <mxGraphModel dx="1560" dy="960" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Dear Diary Multi-Device Sync&#xa;Google identity + Supabase metadata + encrypted Drive data" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#4B2E4C;" vertex="1" parent="1">
          <mxGeometry x="330" y="20" width="740" height="70" as="geometry" />
        </mxCell>

        <mxCell id="mobile" value="Primary Mobile&#xa;• Account creation&#xa;• One active primary&#xa;• E2EE root key holder&#xa;• Approves companions&#xa;• Local encrypted cache + PIN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#BE5B8C;fontColor=#4B2E4C;fontSize=14;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="190" width="250" height="180" as="geometry" />
        </mxCell>

        <mxCell id="web" value="Web Companion&#xa;• Existing account only&#xa;• Google login&#xa;• QR/pairing approval&#xa;• Online edits only&#xa;• Local cache is not authority" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontColor=#123047;fontSize=14;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="450" width="250" height="160" as="geometry" />
        </mxCell>

        <mxCell id="desktop" value="Future Desktop Companion&#xa;• Same companion model&#xa;• Existing account only&#xa;• Online edits only&#xa;• Revoked on primary transfer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontColor=#123047;fontSize=14;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="650" width="250" height="140" as="geometry" />
        </mxCell>

        <mxCell id="google" value="Google Sign-In&#xa;Identity provider only&#xa;OAuth proves Google user" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#5B3A00;fontSize=14;align=center;" vertex="1" parent="1">
          <mxGeometry x="500" y="120" width="230" height="100" as="geometry" />
        </mxCell>

        <mxCell id="supabase" value="Supabase Control Plane&#xa;Metadata only&#xa;&#xa;• Accounts&#xa;• Active primary mobile&#xa;• Device registry&#xa;• Pairing sessions&#xa;• Sync sequence/cursors&#xa;• Drive file IDs + hashes&#xa;• Realtime notifications&#xa;&#xa;Never stores journal plaintext" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontColor=#153A24;fontSize=14;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="480" y="310" width="280" height="260" as="geometry" />
        </mxCell>

        <mxCell id="drive" value="Google Drive appDataFolder&#xa;Encrypted data plane in user's Drive storage&#xa;&#xa;• Encrypted event chunks&#xa;• Encrypted media blobs&#xa;• Encrypted periodic snapshots&#xa;• Encrypted root-key recovery package&#xa;&#xa;Hidden from normal Drive UI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#7E22CE;fontColor=#33124D;fontSize=14;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="930" y="300" width="310" height="240" as="geometry" />
        </mxCell>

        <mxCell id="passphrase" value="Recovery Passphrase&#xa;12+ characters&#xa;Never stored&#xa;Wraps account root key&#xa;Required when primary mobile is lost" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE4E6;strokeColor=#E11D48;fontColor=#5D1023;fontSize=14;align=center;" vertex="1" parent="1">
          <mxGeometry x="500" y="660" width="250" height="130" as="geometry" />
        </mxCell>

        <mxCell id="events" value="Encrypted Sync Event&#xa;create / update / delete&#xa;record version + sequence" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFFFFF;strokeColor=#64748B;fontColor=#1F2937;fontSize=13;align=center;" vertex="1" parent="1">
