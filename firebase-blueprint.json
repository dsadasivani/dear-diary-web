{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account details and goals",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "bio": { "type": "string" },
        "avatarEmoji": { "type": "string" },
        "avatarColor": { "type": "string" },
        "writingGoal": { "type": "number" },
        "joinedDate": { "type": "string" }
      },
      "required": ["name", "email"]
    },
    "Diary": {
      "title": "Diary",
      "description": "A diary book containing entries",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "emoji": { "type": "string" },
        "color": { "type": "string" },
        "isLocked": { "type": "boolean" },
        "entryCount": { "type": "number" },
        "lastUpdated": { "type": "string" },
        "coverImage": { "type": "string" },
        "foilIcons": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["id", "name", "emoji", "color", "isLocked"]
    },
    "Entry": {
      "title": "Entry",
      "description": "A journal entry in a diary",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "diaryId": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "moodName": { "type": "string" },
        "moodEmoji": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "photoUris": {
          "type": "array",
          "items": { "type": "string" }
        },
        "photoCount": { "type": "number" },
        "wordCount": { "type": "number" },
        "audioUri": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "isTimelineBifurcated": { "type": "boolean" }
      },
      "required": [
        "id",
        "diaryId",
        "date",
        "title",
        "body",
        "moodName",
        "moodEmoji",
        "createdAt",
        "updatedAt"
      ]
    },
    "Note": {
      "title": "Note",
      "description": "A standalone quick note",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "isPinned": { "type": "boolean" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "title", "body", "isPinned", "createdAt", "updatedAt"]
    },
    "AppSettings": {
      "title": "App Settings",
      "description": "General application configurations and preferences",
      "type": "object",
      "properties": {
        "remindersEnabled": { "type": "boolean" },
        "reminderTime": { "type": "string" },
        "customTags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "customMoods": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "emoji": { "type": "string" }
            }
          }
        },
        "theme": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "Stores profile details of the user"
    },
    "users/{userId}/diaries/{diaryId}": {
      "schema": "Diary",
      "description": "Stores user diaries"
    },
    "users/{userId}/entries/{entryId}": {
      "schema": "Entry",
      "description": "Stores diary entries for user"
    },
    "users/{userId}/notes/{noteId}": {
      "schema": "Note",
      "description": "Stores quick standalone notes"
    },
    "users/{userId}/settings/{settingsId}": {
      "schema": "AppSettings",
      "description": "Stores general app settings"
    }
  }
}
