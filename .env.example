# Required for native Android/iOS Google Sign-In and Drive appDataFolder backup.
# Use the Google Cloud OAuth 2.0 "Web application" client ID, not the Android client ID.
VITE_GOOGLE_WEB_CLIENT_ID=""

# Multi-device encrypted sync metadata control plane.
# Apply docs/supabase/001 through docs/supabase/018 in order to this Supabase project.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# Manual MD-021/MD-022 force-stop testing only. Never enable in release builds.
VITE_ENABLE_MD_FLOW_HOOKS=""

# Android manual inspection. Keep bridge logging off for sync/recovery tests.
CAPACITOR_WEBVIEW_DEBUG=""
CAPACITOR_BRIDGE_LOGGING=""
VITE_MINIMUM_PROTOCOL_VERSION=1
VITE_TELEMETRY_RELEASE_VERSION=local-development
