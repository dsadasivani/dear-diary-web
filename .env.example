# Required for native Android/iOS Google Sign-In and Drive appDataFolder backup.
# Use the Google Cloud OAuth 2.0 "Web application" client ID, not the Android client ID.
VITE_GOOGLE_WEB_CLIENT_ID=""

# Multi-device encrypted sync metadata control plane.
# Apply docs/supabase/001 through docs/supabase/018 in order to this Supabase project.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# Manual MD-021/MD-022 force-stop testing only. Never enable in release builds.
VITE_ENABLE_MD_FLOW_HOOKS=""

# Android manual inspection. Keep bridge logging off for sync/recovery tests.
CAPACITOR_WEBVIEW_DEBUG=""
CAPACITOR_BRIDGE_LOGGING=""
VITE_MINIMUM_PROTOCOL_VERSION=1
VITE_TELEMETRY_RELEASE_VERSION=local-development

# Spring Boot Sync V2 backend. JWT stays fail-closed until explicitly enabled.
SYNC_DB_URL="jdbc:postgresql://localhost:5432/dear_diary_sync"
SYNC_DB_USERNAME="dear_diary_sync"
SYNC_DB_PASSWORD=""
SYNC_JWT_ENABLED="false"
SYNC_JWT_ISSUER_URI="https://YOUR_PROJECT_REF.supabase.co/auth/v1"
SYNC_JWT_JWK_SET_URI="https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json"
SYNC_JWT_AUDIENCE="authenticated"
SYNC_OBJECT_STORE_ENABLED="false"
SYNC_OBJECT_STORE_BUCKET=""
SYNC_OBJECT_STORE_REGION="us-east-1"
SYNC_OBJECT_STORE_ENDPOINT=""
SYNC_OBJECT_STORE_PATH_STYLE="false"
SYNC_NOTIFICATION_PUBLISHER_ENABLED="false"
SYNC_NOTIFICATION_PUBLISHER_ENDPOINT=""
SYNC_NOTIFICATION_PUBLISHER_TOKEN=""
SYNC_NOTIFICATION_PUBLISHER_TIMEOUT="5s"
SYNC_NOTIFICATION_WORKER_ENABLED="false"
SYNC_NOTIFICATION_WORKER_POLL_INTERVAL="5s"
SYNC_NOTIFICATION_WORKER_LEASE_DURATION="30s"
SYNC_NOTIFICATION_RETRY_BASE_DELAY="5s"
SYNC_NOTIFICATION_MAX_ATTEMPTS="10"
SYNC_NOTIFICATION_MAX_BATCH_SIZE="100"
