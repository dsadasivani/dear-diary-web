{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "GitHubStagingEnvironment",
      "Effect": "Allow",
      "Principal": {
        "Federated": "arn:aws:iam::908027418886:oidc-provider/token.actions.githubusercontent.com"
      },
      "Action": "sts:AssumeRoleWithWebIdentity",
      "Condition": {
        "StringEquals": {
          "token.actions.githubusercontent.com:aud": "sts.amazonaws.com",
          "token.actions.githubusercontent.com:sub": "repo:dsadasivani/dear-diary-web:environment:staging"
        }
      }
    }
  ]
}
