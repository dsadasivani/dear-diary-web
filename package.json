{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test:storage": "tsx --test src/domain/appSettings.test.ts && tsx --test src/domain/backupMerge.test.ts && tsx --test src/domain/security.test.ts && tsx --test src/mobile/mediaGarbageCollector.test.ts && tsx --test src/repositories/localDiaryRepository.test.ts && tsx --test src/utils/backupEncryption.test.ts && tsx --test src/utils/backupSnapshot.test.ts && tsx --test src/utils/googleProfile.test.ts && tsx --test src/utils/manualBackup.test.ts",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "cap:sync": "cap sync",
    "cap:copy": "cap copy",
    "android": "cap run android",
    "android:studio": "cap open android",
    "android:lint": "cd android && gradlew.bat --no-daemon lintDebug",
    "android:test": "cd android && gradlew.bat --no-daemon testDebugUnitTest",
    "android:release": "cd android && gradlew.bat --no-daemon assembleRelease",
    "android:bundle": "cd android && gradlew.bat --no-daemon bundleRelease",
    "assets:generate": "npx @capacitor/assets generate --android --assetPath resources --iconBackgroundColor \"#232427\" --iconBackgroundColorDark \"#17181a\" --splashBackgroundColor \"#232427\" --splashBackgroundColorDark \"#17181a\" --logoSplashScale 0.36",
    "mobile:build": "npm run build",
    "mobile:sync": "npm run mobile:build && cap sync"
  },
  "dependencies": {
    "@aparajita/capacitor-secure-storage": "^8.0.0",
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capawesome/capacitor-google-sign-in": "^0.1.2",
    "@capgo/capacitor-native-biometric": "^8.4.12",
    "@independo/capacitor-voice-recorder": "^8.3.3",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fflate": "^0.8.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
